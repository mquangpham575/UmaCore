# UmaCore Local Environment Template
DISCORD_TOKEN=your_bot_token_here
DATABASE_URL=postgresql://umacore:mypassword@localhost:5432/umacore
LOG_LEVEL=INFO
USE_UMAMOE_API=false
# Optional GitHub raw base URL override for club tracking JSON.
# Scraper reads <base_url>/<circle_id>.json before falling back to Uma.moe API.
UMAMOE_RAW_DATA_BASE_URL=https://raw.githubusercontent.com/mquangpham575/Uma_Club_Fan_Tracking/main/api_data

# Optional GitHub API Token for higher rate limits and private repo access.
GITHUB_TOKEN=your_github_pat_here

# Database Settings (Used by docker-compose)
POSTGRES_PASSWORD=mypassword
